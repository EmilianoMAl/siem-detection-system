# Copia este archivo a ".env" en la raíz del repo (mismo directorio que
# docker-compose.yml) y llena los valores. ".env" está en .gitignore —
# nunca lo subas a GitHub.

# Secreto compartido que debe mandar agent/ship_logs.py en el header
# X-Sentinel-Token para poder mandar eventos a POST /ingest. Genera uno
# con: python -c "import secrets; print(secrets.token_hex(32))"
SENTINEL_INGEST_TOKEN=

# Agente real (opcional): representa el host donde corre SENTINEL,
# reportando su propio tráfico SSH/web genuino. Si dejas
# SENTINEL_REAL_AGENT_HOSTNAME vacío, no se registra ningún agente real
# y todo sigue funcionando solo con la flota simulada.
SENTINEL_REAL_AGENT_HOSTNAME=
SENTINEL_REAL_AGENT_IP=
SENTINEL_REAL_AGENT_OS=Ubuntu 24.04 LTS (Oracle Cloud)

# Cada cuántos segundos la API genera un lote nuevo de actividad
# simulada para que los agentes no se vean DISCONNECTED y el dashboard
# no se vea igual en cada refresh.
SENTINEL_SIMULATION_TICK_SECONDS=300
